<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CENG 382</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<header class="topbar">
    <a class="brand" asp-area="" asp-page="/Index">CENG 382</a>
    <ul class="topbar-nav">
        <li><a asp-area="" asp-page="/Index">Gallery</a></li>
        <li><a asp-area="" asp-page="/Privacy">Privacy</a></li>
    </ul>
    <div class="topbar-right">
        <partial name="_LoginPartial" />
    </div>
</header>

<div class="layout">
    <nav class="sidebar">
        <span class="sidebar-group">Main</span>
        <a class="slink" asp-area="" asp-page="/Index">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            Gallery
        </a>
        <a class="slink" asp-area="" asp-page="/Privacy">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Privacy
        </a>

        <span class="sidebar-group">Account</span>
        <a class="slink" asp-area="Identity" asp-page="/Account/Register">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
            </svg>
            Register
        </a>
        <a class="slink" asp-area="Identity" asp-page="/Account/Login">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                <polyline points="10 17 15 12 10 7"/>
                <line x1="15" y1="12" x2="3" y2="12"/>
            </svg>
            Login
        </a>
    </nav>

    <div class="content">
        @RenderBody()
    </div>
</div>

<footer class="footer">
    <span>&copy; @DateTime.Now.Year CENG 382</span>
    <span>Bilgisayar Mühendisliği</span>
</footer>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
