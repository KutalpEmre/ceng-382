@using Microsoft.AspNetCore.Identity
@using Ceng382.Models.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <span class="user-chip">@UserManager.GetUserName(User)</span>
    <form asp-area="Identity" asp-page="/Account/Logout"
          asp-route-returnUrl="@Url.Page("/Index", new { area = "" })"
          method="post" style="display:inline;">
        <button type="submit" class="btn-danger-ghost">Sign out</button>
    </form>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Login" class="btn-ghost">Sign in</a>
    <a asp-area="Identity" asp-page="/Account/Register" class="btn-ghost fill">Get started</a>
}
