@page
@model Ceng382.Pages.Northwind.CustomersModel
@{
    ViewData["Title"] = "Customers";
}

<div class="pg-head">
    <h1 class="pg-title">Customers</h1>
    <p class="pg-sub">Northwind müşterileri — şirket ve iletişim bilgileriyle.</p>
</div>

<div class="stats-row">
    <div class="stat-box pink">
        <div class="stat-label">Total Customers</div>
        <div class="stat-val">@Model.Customers.Count</div>
    </div>
    <div class="stat-box purple">
        <div class="stat-label">Countries</div>
        <div class="stat-val">@Model.Customers.Select(c => c.Country).Distinct().Count()</div>
    </div>
    <div class="stat-box blue">
        <div class="stat-label">Cities</div>
        <div class="stat-val">@Model.Customers.Select(c => c.City).Distinct().Count()</div>
    </div>
</div>

<div class="card">
    <div class="ch">
        <span class="ch-dot" style="background:#22d3ee;"></span>
        <span class="ch-title">Customer List</span>
        <span class="ch-badge">@Model.Customers.Count total</span>
    </div>
    <table class="users-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Company</th>
                <th>Contact</th>
                <th>Title</th>
                <th>City</th>
                <th>Country</th>
                <th>Phone</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Customers)
            {
                <tr>
                    <td style="color:#475569;font-size:0.75rem;font-weight:700;">@c.CustomerID</td>
                    <td>@c.CompanyName</td>
                    <td>@(c.ContactName ?? "—")</td>
                    <td style="color:#94a3b8;font-size:0.8rem;">@(c.ContactTitle ?? "—")</td>
                    <td>@(c.City ?? "—")</td>
                    <td style="color:#64748b;font-size:0.8rem;">@(c.Country ?? "—")</td>
                    <td style="color:#64748b;font-size:0.8rem;">@(c.Phone ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
