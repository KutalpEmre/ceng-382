@page
@model Ceng382.Pages.Northwind.ProductsModel
@{
    ViewData["Title"] = "Products";
}

<div class="pg-head">
    <h1 class="pg-title">Products</h1>
    <p class="pg-sub">Northwind veritabanındaki tüm ürünler — kategori ve tedarikçi bilgileriyle.</p>
</div>

<div class="stats-row">
    <div class="stat-box pink">
        <div class="stat-label">Total Products</div>
        <div class="stat-val">@Model.Products.Count</div>
    </div>
    <div class="stat-box purple">
        <div class="stat-label">Active</div>
        <div class="stat-val">@Model.Products.Count(p => !p.Discontinued)</div>
    </div>
    <div class="stat-box blue">
        <div class="stat-label">Discontinued</div>
        <div class="stat-val">@Model.Products.Count(p => p.Discontinued)</div>
    </div>
</div>

<div class="card">
    <div class="ch">
        <span class="ch-dot" style="background:#34d399;"></span>
        <span class="ch-title">Product List</span>
        <span class="ch-badge">@Model.Products.Count total</span>
    </div>
    <table class="users-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Supplier</th>
                <th>Unit Price</th>
                <th>In Stock</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Products)
            {
                <tr>
                    <td style="color:#475569;font-size:0.75rem;">@p.ProductID</td>
                    <td>@p.ProductName</td>
                    <td style="color:#94a3b8;">@(p.Category?.CategoryName ?? "—")</td>
                    <td style="color:#64748b;font-size:0.8rem;">@(p.Supplier?.CompanyName ?? "—")</td>
                    <td style="color:#34d399;">$@(p.UnitPrice?.ToString("F2") ?? "—")</td>
                    <td>@(p.UnitsInStock?.ToString() ?? "—")</td>
                    <td>
                        @if (p.Discontinued)
                        {
                            <span style="font-size:0.7rem;padding:0.15rem 0.5rem;border-radius:20px;background:rgba(244,63,94,0.12);color:#f87171;font-weight:700;">Discontinued</span>
                        }
                        else
                        {
                            <span style="font-size:0.7rem;padding:0.15rem 0.5rem;border-radius:20px;background:rgba(52,211,153,0.12);color:#34d399;font-weight:700;">Active</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
